{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lyrit-loom.local/contracts/transcriber.schema.json",
  "title": "Lyrit Loom transcriber process contract",
  "oneOf": [{ "$ref": "#/$defs/request" }, { "$ref": "#/$defs/result" }],
  "$defs": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "request_id",
        "input_path",
        "output_path",
        "language",
        "model",
        "word_timestamps",
        "vad"
      ],
      "properties": {
        "contract_version": { "const": "1" },
        "request_id": { "type": "string", "format": "uuid" },
        "input_path": { "type": "string", "minLength": 1 },
        "output_path": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "word_timestamps": { "const": true },
        "vad": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": { "enabled": { "type": "boolean" } }
        },
        "initial_prompt": { "type": ["string", "null"] }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "language",
        "language_probability",
        "duration_ms",
        "model",
        "segments",
        "warnings"
      ],
      "properties": {
        "contract_version": { "const": "1" },
        "language": { "type": "string", "minLength": 1 },
        "language_probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "duration_ms": { "type": "integer", "minimum": 1 },
        "model": {
          "type": "object",
          "additionalProperties": false,
          "required": ["engine", "name", "revision"],
          "properties": {
            "engine": { "type": "string", "enum": ["fake", "faster-whisper"] },
            "name": { "type": "string", "minLength": 1 },
            "revision": { "type": "string", "minLength": 1 }
          }
        },
        "segments": {
          "type": "array",
          "items": { "$ref": "#/$defs/segment" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_ms", "end_ms", "text", "words"],
      "properties": {
        "start_ms": { "type": "integer", "minimum": 0 },
        "end_ms": { "type": "integer", "minimum": 1 },
        "text": { "type": "string" },
        "words": {
          "type": "array",
          "items": { "$ref": "#/$defs/word" }
        }
      }
    },
    "word": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "start_ms", "end_ms", "confidence"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "start_ms": { "type": "integer", "minimum": 0 },
        "end_ms": { "type": "integer", "minimum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}

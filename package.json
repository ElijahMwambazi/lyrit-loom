    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@redocly/cli": "2.19.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  }
}

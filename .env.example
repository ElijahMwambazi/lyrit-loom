DATABASE_URL=postgres://lyrit:lyrit@localhost:5432/lyrit
API_BIND=0.0.0.0:8080
ENABLE_DEV_ROUTES=true
RUST_LOG=lyrit_api=debug,lyrit_worker=debug,tower_http=info
LOG_FORMAT=pretty

WORKER_ID=local-worker
WORKER_POLL_MS=750
WORKER_LEASE_SECONDS=30
WORKER_RUN_ONCE=false
WORKER_QUEUES=system_probe,transcribe

LYRIT_TRANSCRIBER_MODE=fake
TRANSCRIBER_MODEL=configured-default
PYTHONPATH=apps/transcriber/src

ARTIFACT_STORE=local
ARTIFACT_ROOT=./artifacts
FFPROBE_PATH=ffprobe
WORKSPACE_ROOT=./workspaces
FFMPEG_PATH=ffmpeg
PYTHON_PATH=python3
MAX_UPLOAD_BYTES=536870912
MAX_AUDIO_DURATION_MS=900000
AUTH_MODE=disabled

VITE_API_BASE_URL=/api/v1
